MEALIE_HOST=http://mealie:9000
MEALIE_TOKEN=your-mealie-api-token
PICNIC_USERNAME=your-picnic-email
PICNIC_PASSWORD=your-picnic-password
PICNIC_AUTH_TOKEN=
PICNIC_COUNTRY_CODE=NL
FUZZY_THRESHOLD=65

# LLM Matching (optional - improves product matching accuracy)
ANTHROPIC_API_KEY=
LLM_MATCHING_ENABLED=false
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_PRODUCTS_PER_ITEM=15

# Recipe photo audit (optional)
OPENAI_API_KEY=
BRAVE_API_KEY=

# Recipe audit settings
AUDIT_TARGET_LANGUAGE=nl
AUDIT_PARSER=openai
AUDIT_LLM_PROVIDER=anthropic
